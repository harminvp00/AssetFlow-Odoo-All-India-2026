# Server settings
PORT=5000
NODE_ENV=development

# Database connection
DATABASE_URL="postgresql://username:password@localhost:5432/assetflow?schema=public"

# Auth secrets
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
JWT_REFRESH_SECRET=super_secret_jwt_refresh_signing_key_change_me
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Google OAuth details
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Cloudinary assets storage
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Rate limiter limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
