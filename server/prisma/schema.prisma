  setting_key        String   @unique(map: "uq_app_settings_key") @db.VarChar(96)
  setting_value      String
  value_type         String   @default("STRING") @db.VarChar(16)
  description        String?
  updated_by_user_id BigInt?
  updated_at         DateTime @default(now()) @db.Timestamptz(6)
  users              users?   @relation(fields: [updated_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
