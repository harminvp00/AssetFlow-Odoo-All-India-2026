/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model approval_history {
  id                  BigInt            @id @default(autoincrement())
  approval_request_id BigInt
  action_id           BigInt
  actor_user_id       BigInt?
  acted_at            DateTime          @default(now()) @db.Timestamptz(6)
  remarks             String?
  lookup_values       lookup_values     @relation(fields: [action_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users?            @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approval_requests   approval_requests @relation(fields: [approval_request_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([approval_request_id, acted_at], map: "ix_approval_history_request")
