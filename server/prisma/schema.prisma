/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asset_attachments {
  asset_id        BigInt
  attachment_id   BigInt
  attachment_role String      @default("PHOTO") @db.VarChar(32)
  assets          assets      @relation(fields: [asset_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  attachments     attachments @relation(fields: [attachment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([asset_id, attachment_id])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asset_categories {
  id                      BigInt             @id @default(autoincrement())
  name                    String             @db.VarChar(128)
  code                    String             @unique(map: "uq_asset_categories_code") @db.VarChar(32)
  parent_category_id      BigInt?
  description             String?
  default_warranty_months Int?               @db.SmallInt
  status_id               BigInt
  created_at              DateTime           @default(now()) @db.Timestamptz(6)
  updated_at              DateTime           @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?          @db.Timestamptz(6)
  asset_categories        asset_categories?  @relation("asset_categoriesToasset_categories", fields: [parent_category_id], references: [id], onUpdate: NoAction)
  other_asset_categories  asset_categories[] @relation("asset_categoriesToasset_categories")
  lookup_values           lookup_values      @relation(fields: [status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assets                  assets[]

  @@index([parent_category_id], map: "ix_asset_categories_parent")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asset_condition_history {
  id                                                                         BigInt         @id @default(autoincrement())
  asset_id                                                                   BigInt
  previous_condition_id                                                      BigInt?
  new_condition_id                                                           BigInt
  recorded_by_user_id                                                        BigInt?
  recorded_at                                                                DateTime       @default(now()) @db.Timestamptz(6)
  source_entity_type_id                                                      BigInt?
