model users {
  id                                                                      BigInt                       @id @default(autoincrement())
  public_id                                                               String                       @unique(map: "uq_users_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                                   String                       @unique(map: "uq_users_email") @db.Citext
  password_hash                                                           String
  password_algo                                                           String                       @default("bcrypt") @db.VarChar(32)
  password_changed_at                                                     DateTime?                    @db.Timestamptz(6)
  email_verified_at                                                       DateTime?                    @db.Timestamptz(6)
  account_status_id                                                       BigInt
  failed_login_count                                                      Int                          @default(0) @db.SmallInt
  last_login_at                                                           DateTime?                    @db.Timestamptz(6)
  created_at                                                              DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                                                              DateTime                     @default(now()) @db.Timestamptz(6)
  deleted_at                                                              DateTime?                    @db.Timestamptz(6)
  activity_logs                                                           activity_logs[]
  app_settings                                                            app_settings[]
  approval_history                                                        approval_history[]
  approval_requests_approval_requests_decided_by_user_idTousers           approval_requests[]          @relation("approval_requests_decided_by_user_idTousers")
  approval_requests_approval_requests_requested_by_user_idTousers         approval_requests[]          @relation("approval_requests_requested_by_user_idTousers")
  asset_allocations                                                       asset_allocations[]
  asset_condition_history                                                 asset_condition_history[]
  asset_lifecycle_events                                                  asset_lifecycle_events[]
  asset_location_history                                                  asset_location_history[]
  asset_return_requests_asset_return_requests_inspected_by_user_idTousers asset_return_requests[]      @relation("asset_return_requests_inspected_by_user_idTousers")
  asset_return_requests_asset_return_requests_requested_by_user_idTousers asset_return_requests[]      @relation("asset_return_requests_requested_by_user_idTousers")
  asset_transfer_requests                                                 asset_transfer_requests[]
  attachments                                                             attachments[]
  audit_cycle_auditors                                                    audit_cycle_auditors[]
  audit_cycles_audit_cycles_closed_by_user_idTousers                      audit_cycles[]               @relation("audit_cycles_closed_by_user_idTousers")
  audit_cycles_audit_cycles_created_by_user_idTousers                     audit_cycles[]               @relation("audit_cycles_created_by_user_idTousers")
  audit_discrepancies                                                     audit_discrepancies[]
  booking_reschedule_history                                              booking_reschedule_history[]
  department_head_history                                                 department_head_history[]
  employees                                                               employees?
  login_history                                                           login_history[]
  maintenance_requests_maintenance_requests_approved_by_user_idTousers    maintenance_requests[]       @relation("maintenance_requests_approved_by_user_idTousers")
  maintenance_requests_maintenance_requests_raised_by_user_idTousers      maintenance_requests[]       @relation("maintenance_requests_raised_by_user_idTousers")
  maintenance_status_history                                              maintenance_status_history[]
  notification_recipients                                                 notification_recipients[]
  password_reset_tokens                                                   password_reset_tokens[]
  resource_bookings_resource_bookings_booked_by_user_idTousers            resource_bookings[]          @relation("resource_bookings_booked_by_user_idTousers")
  resource_bookings_resource_bookings_cancelled_by_user_idTousers         resource_bookings[]          @relation("resource_bookings_cancelled_by_user_idTousers")
  user_sessions                                                           user_sessions[]
  lookup_values                                                           lookup_values                @relation(fields: [account_status_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([account_status_id], map: "ix_users_account_status")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PENDING_PAYMENT
  PAID
  OVERDUE
}

enum POStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
  CLOSED
}

enum QuotationStatus {
  DRAFT
  SUBMITTED
  SELECTED
  REJECTED
}

enum RFQStatus {
  DRAFT
  OPEN
  IN_REVIEW
  CLOSED
}

enum Role {
  ADMIN
  PROCUREMENT_OFFICER
  VENDOR
  MANAGER
}

enum VendorStatus {
  PENDING
  ACTIVE
  BLOCKED
}
